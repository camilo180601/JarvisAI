# ╔══════════════════════════════════════════════════════════════╗
# ║  JARVIS — API keys y secretos                                   ║
# ║  Copiá este archivo a ".env" y completá lo que vayas a usar.    ║
# ║  El .env tiene prioridad sobre config/api_keys.json.           ║
# ║  NO subir el .env a git.                                        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Cerebros de IA (consult_model / model_config) ──
# Gemini es OBLIGATORIO (voz + cerebro por defecto). El resto son opcionales.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=

# ── Contenido / multimedia ──
# TMDB (info de pelis y series) — https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Figma (token personal) — figma.com → Settings → Personal access tokens
FIGMA_TOKEN=

# ── Spotify (música) — https://developer.spotify.com/dashboard ──
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ── Casa inteligente (Tuya / Smart Life) — https://iot.tuya.com ──
TUYA_API_KEY=
TUYA_API_SECRET=
TUYA_REGION=us
# Philips Hue (opcional): IP del Bridge. Si se deja vacío, JARVIS lo descubre solo.
HUE_BRIDGE_IP=

# ── Trading (broker real Alpaca) — solo si pasás el bot a dinero real ──
# Cuenta gratis en https://alpaca.markets → API Keys. Empezá con las de "Paper"
# (broker real, plata ficticia) para validar; las de "Live" mueven dinero REAL.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Integraciones MCP (las usan los servidores en config/mcp_servers.json) ──
# GitHub (repos, issues, PRs) — https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=
# Telegram bot — hablá con @BotFather
TELEGRAM_BOT_API_TOKEN=
# Brave Search — https://brave.com/search/api
BRAVE_API_KEY=
# Notion — https://www.notion.so/my-integrations
NOTION_API_KEY=
# Composio (conector multi-app) — https://app.composio.dev
COMPOSIO_API_KEY=
